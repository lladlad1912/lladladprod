# Copy to /etc/lladlad/backend.env on the VPS
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:mysql://localhost:3306/blogdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=lladlad
DB_PASSWORD=change-me

JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits
JWT_EXPIRATION=86400000

CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
SITE_URL=https://www.yourdomain.com

FILE_UPLOAD_DIR=/var/lib/lladlad/uploads

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
