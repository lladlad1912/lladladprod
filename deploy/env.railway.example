# Railway backend variables (Settings → Variables)

SPRING_PROFILES_ACTIVE=prod

# MySQL — paste from your provider (PlanetScale, Railway MySQL template, etc.)
DB_URL=jdbc:mysql://HOST:3306/blogdb?useSSL=true&serverTimezone=UTC
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password

JWT_SECRET=generate-a-long-random-string-at-least-256-bits
JWT_EXPIRATION=86400000

CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
SITE_URL=https://your-app.vercel.app

FILE_UPLOAD_DIR=/data/uploads

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
