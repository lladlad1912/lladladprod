[Unit]
Description=Lladlad Spring Boot Backend
After=network.target mysql.service

[Service]
Type=simple
User=lladlad
Group=lladlad
WorkingDirectory=/opt/lladlad
EnvironmentFile=/etc/lladlad/backend.env
ExecStart=/usr/bin/java -jar /opt/lladlad/blog-application.jar
Restart=on-failure
RestartSec=10
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target
