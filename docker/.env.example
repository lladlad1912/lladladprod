# Copy to docker/.env and edit before deploy

# Public site URL (used for React build + CORS + SSL)
# Use https://www after SSL is enabled; http://YOUR_VPS_IP for first bootstrap test
SITE_URL=https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# GoDaddy / DNS — point A records for @ and www to your VPS public IP

# Domain for Let's Encrypt (usually bare domain; cert covers www via -d flags in init script)
DOMAIN=yourdomain.com
LETSENCRYPT_DOMAIN=yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=blogdb
MYSQL_USER=lladlad
MYSQL_PASSWORD=change-me-db

# Backend
JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits
JWT_EXPIRATION=86400000

# Optional
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
